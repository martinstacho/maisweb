rapper"><div class="wpb_text_column wpb_content_element " ><div class="wpb_wrapper"><h4 style="text-align: center;">Aktivity katedry Urgentnej zdravotnej starostlivosti</h4></div></div><div class="vc_empty_space"   style="height: 32px"><span class="vc_empty_space_inner"></span></div><div class="vc_row wpb_row vc_inner vc_row-fluid"><div class="wpb_column vc_column_container vc_col-sm-3"><div class="vc_column-inner"><div class="wpb_wrapper"><div  class="wpb_single_image wpb_content_element vc_align_left"><figure class="wpb_wrapper vc_figure">

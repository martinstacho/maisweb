"><div class="wpb_text_column wpb_content_element " ><div class="wpb_wrapper"><h3 style="text-align: center;">Harmonogram akademického roka</h3></div></div><div class="vc_empty_space"   style="height: 32px"><span class="vc_empty_space_inner"></span></div></div></div></div></div><div class="vc_row wpb_row vc_row-fluid"><div class="wpb_column vc_column_container vc_col-sm-6"><div class="vc_column-inner"><div class="wpb_wrapper"><div class="vc_btn3-container vc_btn3-center" ><a class="vc_general vc_btn3 vc_btn3-size-md vc_btn3-shape-rounded vc_btn3-style-classic vc_btn3-block vc_btn3-icon-left vc_btn3-color-default" href="https://eszu.sk/wp-content/uploads/Harmonogram-AR-FZ-denne.pdf" title="" target="_blank"><i class="vc_btn3-icon far fa-eye"></i> Denné štúdium</a></div></div></div></div><div class="wpb_column vc_column_container vc_col-sm-6"><div class="vc_column-inner"><div class="wpb_wrapper"><div class="vc_btn3-container vc_btn3-center" ><a class="vc_general vc_btn3 vc_btn3-size-md vc_btn3-shape-rounded vc_btn3-style-classic vc_btn3-block vc_btn3-icon-left vc_btn3-color-default" href="https://eszu.sk/wp-content/uploads/Harmonogram-AR-FZ-externe.pdf" title="" target="_blank"><i class="vc_btn3-icon far fa-eye"></i> Externé štúdium</a></div></div></div></div></div></p></div>

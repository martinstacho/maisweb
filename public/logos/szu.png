b_wrapper"><div class="wpb_text_column wpb_content_element " ><div class="wpb_wrapper"><h3 style="text-align: center;"><strong>Informačné listy predmetov &#8211; General Medicine</strong></h3></div></div><div class="vc_separator wpb_content_element vc_separator_align_center vc_sep_width_100 vc_sep_pos_align_center vc_separator_no_text vc_sep_color_grey wpb_content_element  wpb_content_element" ><span class="vc_sep_holder vc_sep_holder_l"><span class="vc_sep_line"></span></span><span class="vc_sep_holder vc_sep_holder_r"><span class="vc_sep_line"></span></span></div><div class="vc_empty_space"   style="height: 32px"><span class="vc_empty_space_inner"></span></div><div class="wpb_text_column wpb_content_element " ><div class="wpb_wrapper"><table id="tablepress-16" class="tablepress tablepress-id-16"><thead><tr class="row-1"><th class="column-1">PREDMET</th></tr></thead><tbody class="row-striping row-hover"><tr class="row-2"><td class="column-1"><a href="https://eszu.sk/wp-content/uploads/Anatomy.pdf" rel="noopener" target="_blank">Anatomy</a></td></tr><tr class="row-3"><td class="column-1"><a href="https://eszu.sk/wp-content/uploads/Anesthesiology-and-Intensive-Medicine.pdf" rel="noopener" target="_blank">Anesthesiology and Intensive Medicine</a></td></tr><tr class="row-4"><td class="column-1"><a href="https://eszu.sk/wp-content/uploads/Clinical-Bioethics.pdf" rel="noopener" target="_blank">Clinical Bioethics</a></td></tr><tr class="row-5"><td class="column-1"><a href="https://eszu.sk/wp-content/uploads/Clinical-Genetics.pdf" rel="noopener" target="_blank">Clinical Genetics</a></td></tr><tr class="row-6"><td class="column-1"><a href="https://eszu.sk/wp-content/uploads/Clinical-Pharmacology.pdf" rel="noopener" target="_blank">Clinical Pharmacology</a></td></tr><tr class="row-7"><td class="column-1"><a href="https://eszu.sk/wp-content/uploads/Clinical-Practice-Gynaecology-and-Obstetrics.pdf" rel="noopener" target="_blank">Clinical Practice - Gynaecology and Obstetrics</